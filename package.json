{
  "name": "podium",
  "version": "1.0.0",
  "description": "Podium — Dutch theatre social platform",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"magenta,cyan\" \"npm run server\" \"npm run client\"",
    "server": "npm run dev --prefix \"Podium App/server\"",
    "client": "npm run dev --prefix \"Podium App/client\"",
    "update-theatres": "node scripts/update-theatres.js",
    "enrich-theatre-logos": "node scripts/enrich-theatre-logos.js",
    "scrape-shows": "node scripts/scrape-shows.js",
    "enrich-shows": "node scripts/enrich-shows.js",
    "import-shows": "node scripts/import-shows.js",
    "migrate-sqlite-to-split": "node scripts/migrate-sqlite-to-split.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "concurrently": "^10.0.3",
    "puppeteer": "^25.1.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "mongodb": "^7.3.0",
    "pg": "^8.21.0"
  }
}
